# ─── LLM Provider ─────────────────────────────────────────
# MiroFish uses an OpenAI-compatible interface.
# Gemini is configured here via its OpenAI-compatible endpoint.
LLM_API_KEY=your-gemini-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.0-flash

# ─── Supabase ─────────────────────────────────────────────
# Use the SERVICE ROLE key (not anon) — sidecar writes progress server-side
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Server ───────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Simulation Defaults ──────────────────────────────────
MAX_SIMULATION_ROUNDS=10
MAX_AGENTS=30
SIMULATION_TIMEOUT_SECONDS=1800   # 30 minutes hard timeout
